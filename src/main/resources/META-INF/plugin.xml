<idea-plugin>
    <id>com.github.wubxi.stockmonitor</id>
    <name>A/H Stock Monitor</name>
    <version>0.1.13</version>
    <vendor email="wwt@example.com">wubxi</vendor>
    <idea-version since-build="232" until-build="253.*"/>

    <description><![CDATA[
        A lightweight PyCharm tool window for watching A-share, ETF and Hong Kong stock quotes,
        grouped watchlists, holdings, daily trades and realized profit/loss.
    ]]></description>

    <change-notes><![CDATA[
        Added holding profit percentage below the holding profit amount.
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.github.wwt.stockplugin.service.StockStateService"/>
        <toolWindow
                id="Stocks"
                anchor="right"
                icon="/icons/stock.svg"
                factoryClass="com.github.wwt.stockplugin.ui.StockToolWindowFactory"/>
        <applicationConfigurable
                instance="com.github.wwt.stockplugin.ui.StockSettingsConfigurable"
                displayName="A/H Stock Monitor"/>
    </extensions>
</idea-plugin>
